# Database connection (matches the default Postgres credentials in docker-compose.yml)
DATABASE_URL="postgresql://admin:supersecretpassword@localhost:5432/gradebook?schema=public"

# NestJS Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET="somesupersecretjwtsecretkey"
JWT_EXPIRES_IN="1d"

# Redis Cache Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# MinIO / S3 Object Storage Configuration
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadminpassword"
S3_BUCKET_NAME="gradebook-files"
